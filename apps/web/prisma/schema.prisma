generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING
  DISABLED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String
  nickname       String?
  avatarType     String    @default("initials")
  avatarIcon     String?
  avatarColor    String?
  avatarImageUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  preferences    UserPreferences[]
  workspaces     WorkspaceMember[]
  teams          TeamMember[]
  status         UserStatus  @default(ACTIVE)
  leadingProjects Project[]     @relation("ProjectLead")
  projectMemberships ProjectMember[]
  assignedIssues Issue[]
}

model Workspace {
  id              String    @id @default(cuid())
  name            String
  url             String    @unique
  avatarType      String    @default("initials")
  avatarIcon      String?
  avatarColor     String?
  avatarImageUrl  String?
  fiscalYearStart String    @default("January")
  region          String    @default("United States")
  members         WorkspaceMember[]
  preferences     UserPreferences[]
  teams           Team[]
  projects        Project[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, workspaceId])
}

model UserPreferences {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId     String
  defaultHomeView String    @default("active-issues")
  fontSize        String    @default("default")
  usePointerCursor Boolean  @default(false)
  displayFullNames Boolean  @default(false)
  interfaceTheme  String    @default("system")

  @@unique([userId, workspaceId])
}

model Team {
  id             String    @id @default(cuid())
  name           String
  identifier     String
  description    String?
  avatarType     String    @default("initials")
  avatarIcon     String?
  avatarColor    String?
  avatarImageUrl String?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId    String
  members        TeamMember[]
  projects        Project[]
  settings       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([workspaceId, identifier])
  @@index([workspaceId])
}

model TeamMember {
  id        String    @id @default(cuid())
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      TeamRole  @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, teamId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Issue {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      IssueStatus @default(OPEN)
  priority    IssuePriority @default(MEDIUM)
  
  // Relations
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sprint      Sprint?   @relation(fields: [sprintId], references: [id])
  sprintId    String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId String?

  // Assignee
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teamId])
  @@index([projectId])
  @@index([sprintId])
  @@index([milestoneId])
  @@index([assigneeId])
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

model Project {
  id             String    @id @default(cuid())
  name           String
  identifier     String
  description    String?
  avatarType     String    @default("initials")
  avatarIcon     String?
  avatarColor    String?
  avatarImageUrl String?
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId         String
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leadId         String
  lead           User          @relation("ProjectLead", fields: [leadId], references: [id])
  members        ProjectMember[]
  blockedBy      Project[]     @relation("ProjectBlockers")
  blocking       Project[]     @relation("ProjectBlockers")
  sprints        Sprint[]
  milestones     Milestone[]
  issues         Issue[]
  settings       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([workspaceId, identifier])
  @@index([workspaceId])
  @@index([teamId])
}

model Sprint {
  id             String    @id @default(cuid())
  name           String
  identifier     String
  description    String?
  avatarType     String    @default("initials")
  avatarIcon     String?
  avatarColor    String?
  avatarImageUrl String?
  teamId         String
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues         Issue[]
  settings       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([teamId, identifier])
  @@index([teamId])
}

model Milestone {
  id             String    @id @default(cuid())
  name           String
  identifier     String
  description    String?
  avatarType     String    @default("initials")
  avatarIcon     String?
  avatarColor    String?
  avatarImageUrl String?
  teamId         String
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues         Issue[]
  settings       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([teamId, identifier])
  @@index([teamId])
}