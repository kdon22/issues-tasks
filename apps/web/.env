# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/issuestasks_dev"

# Auth (make sure these are properly set in production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_secret_here"
NEXTAUTH_JWT_SECRET="different_complex_secret_32_chars_long"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NODE_ENV="development"

# Email Service
RESEND_API_KEY="re_xxxx_your_actual_resend_key"
SMTP_FROM="noreply@yourdomain.com"

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID="your_actual_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_actual_aws_secret_key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="your-bucket-name"
AWS_BUCKET_URL="https://your-bucket-name.s3.amazonaws.com"

# Security
CORS_ORIGINS="http://localhost:3000"
API_SECRET_KEY="your_api_secret_key_32_chars" 