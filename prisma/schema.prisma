generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String?
  password       String
  nickname       String?
  icon           String?
  iconColor      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  workspaces     WorkspaceMember[]
  preferences    UserPreferences[]
  teamMembers    TeamMember[]
  createdInvites WorkspaceInvite[]
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  url         String            @unique
  members     WorkspaceMember[]
  teams       Team[]
  preferences UserPreferences[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  invites     WorkspaceInvite[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
  members     TeamMember[]
  icon        String?
  iconColor   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  team      Team     @relation(fields: [teamId], references: [id])
  teamId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String
  workspaceId      String
  defaultHomeView  String   @default("list")
  fontSize         String   @default("normal")
  usePointerCursor Boolean  @default(false)
  displayFullNames Boolean  @default(true)
  interfaceTheme   String   @default("system")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  code        String    @unique @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}
