{
  "name": "@issuestasks/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npx nx serve web",
    "build": "npx nx build web",
    "lint": "npx nx lint web",
    "prisma:generate": "prisma generate --schema=./apps/web/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./apps/web/prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=./apps/web/prisma/schema.prisma --force",
    "prisma:push": "cd apps/web && npx prisma db push",
    "prisma:studio": "cd apps/web && npx prisma studio",
    "db:reset": "cd apps/web && npx prisma db push --force-reset",
    "setup-workspace": "cd apps/web && npx tsx scripts/setup-workspace.ts",
    "seed": "tsx apps/web/prisma/seed.ts"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/*"
  ],
  "dependencies": {
    "@auth/core": "^0.37.4",
